# Optional — only needed when deploying frontend separately from backend.
# In local dev the Vite proxy forwards /api → http://localhost:4000 automatically.
VITE_API_URL=https://your-backend.example.com/api/v1

# ── Docker Compose ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in values before running docker-compose up.

# Database password (shared by the db and backend services)
DB_PASSWORD=postgres

# JWT — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/callback
MPESA_ENV=sandbox

# Firebase push notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Frontend origin (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost
